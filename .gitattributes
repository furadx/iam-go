# 统一行尾：仓库内文本一律 LF，避免 Windows CRLF 导致 gofmt / 跨平台差异。
* text=auto eol=lf

# 显式声明源码与文本类型为 LF。
*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
*.sh    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sql   text eol=lf
*.conf  text eol=lf
*.env   text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf

# 二进制文件不做行尾转换。
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
